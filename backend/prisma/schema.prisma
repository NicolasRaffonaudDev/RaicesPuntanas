generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  empleado
  usuario
}

enum StockMovementType {
  entrada
  salida
  ajuste
}

enum InquiryStatus {
  pending
  read
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  role                Role                 @default(usuario)
  passwordHash        String
  failedLoginAttempts Int                  @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime             @default(now())
  audits              AuditLog[]
  ventas              Venta[]
  movimientos         InventarioMovimiento[]
  refreshTokens       RefreshToken[]
  clientesCreados     Cliente[]             @relation("ClienteCreador")
  productosCreados    Producto[]            @relation("ProductoCreador")
  favoritosLotes      LoteFavorito[]
  consultas           Consulta[]
  seguimientosConsulta ConsultaSeguimiento[]
}

model Lote {
  id        Int      @id @default(autoincrement())
  title     String
  price     Int
  size      Int
  amenities Amenity[]
  image     String
  address   String?
  lat       Float
  lng       Float
  description String?
  createdAt DateTime @default(now())
  favoritos LoteFavorito[]
  consultas Consulta[]
  inquiries Inquiry[]
}

model Amenity {
  id    String @id @default(uuid()) @db.Uuid
  name  String @unique
  lotes Lote[]
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  meta      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
}

model Cliente {
  id              String   @id @default(cuid())
  nombre          String
  email           String?  @unique
  telefono        String?
  direccion       String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  ventas          Venta[]
  createdBy       User?    @relation("ClienteCreador", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId, createdAt])
}

model Producto {
  id              Int                   @id @default(autoincrement())
  nombre          String
  sku             String                @unique
  precio          Int
  stock           Int                   @default(0)
  activo          Boolean               @default(true)
  createdByUserId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  ventaItems      VentaItem[]
  movimientos     InventarioMovimiento[]
  createdBy       User?                 @relation("ProductoCreador", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId, createdAt])
}

model Venta {
  id        String     @id @default(cuid())
  clienteId String?
  userId    String
  total     Int
  createdAt DateTime   @default(now())
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  user      User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  items     VentaItem[]

  @@index([userId, createdAt])
  @@index([clienteId, createdAt])
}

model VentaItem {
  id         Int      @id @default(autoincrement())
  ventaId    String
  productoId Int
  cantidad   Int
  precioUnit Int
  subtotal   Int
  venta      Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)
}

model InventarioMovimiento {
  id         String            @id @default(cuid())
  productoId Int
  userId     String?
  tipo       StockMovementType
  cantidad   Int
  motivo     String?
  createdAt  DateTime          @default(now())
  producto   Producto          @relation(fields: [productoId], references: [id], onDelete: Cascade)
  user       User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productoId, createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model LoteFavorito {
  id        String   @id @default(cuid())
  userId    String
  loteId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lote      Lote     @relation(fields: [loteId], references: [id], onDelete: Cascade)

  @@unique([userId, loteId])
  @@index([userId, createdAt])
}

model Consulta {
  id        String   @id @default(cuid())
  userId    String
  loteId    Int?
  asunto    String
  mensaje   String
  estado    String   @default("pendiente")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lote      Lote?    @relation(fields: [loteId], references: [id], onDelete: SetNull)
  seguimientos ConsultaSeguimiento[]

  @@index([userId, createdAt])
  @@index([estado, createdAt])
}

model ConsultaSeguimiento {
  id         String   @id @default(cuid())
  consultaId String
  autorId    String?
  mensaje    String
  esInterno  Boolean  @default(true)
  createdAt  DateTime @default(now())
  consulta   Consulta @relation(fields: [consultaId], references: [id], onDelete: Cascade)
  autor      User?    @relation(fields: [autorId], references: [id], onDelete: SetNull)

  @@index([consultaId, createdAt])
  @@index([autorId, createdAt])
}

model Inquiry {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  message   String
  loteId    Int
  status    InquiryStatus @default(pending)
  createdAt DateTime @default(now())
  lote      Lote     @relation(fields: [loteId], references: [id], onDelete: Cascade)

  @@index([loteId, createdAt])
}
